# Copy to .env (e.g. cp .env.example .env). Required for prisma migrate, api, and docker-compose.

# DB (used by Prisma and Docker Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/taskflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskflow

# API
JWT_SECRET=dev-secret
# NODE_ENV=development   # optional; docker-compose defaults to development

# Web (API URL for browser)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: override ports when running docker-compose
# DB_PORT=5432
# API_PORT=3001
# WEB_PORT=3000
